<p style="color: green"><%= notice %></p>

<% content_for :title, "Tools" %>

<h1>Tools</h1>

<div id="tools">
  <table class="table">
  <thead>
    <tr>
      <th scope="col">Tool</th>
      <th scope="col">Tool Brand</th>
      <th scope="col">Purchase Date</th>
      <th scope="col">Purchase Location</th>
      <th scope="col">Warranty Lenght</th>
      <th scope="col"></th>
    </tr>
  </thead>
  <tbody>
    <% @tools.each do |tool| %>
      <tr>
        <td><%=tool.tool_name%></td>
        <td><%=tool.brand_name%></td>
        <td><%=tool.purchase_date%></td>
        <td><%=tool.purchase_location%></td>
        <td><%=tool.waranty_lenght%></td>
        <td><%= link_to "Show", tool,class:"btn btn-primary" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>

<%= link_to "New tool", new_tool_path, class:"btn btn-primary" %>
